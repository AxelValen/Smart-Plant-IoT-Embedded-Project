# --- Base de datos MongoDB Atlas (o instancia local) ---
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/smartplant

# --- Secreto para firmar y verificar tokens JWT ---
# Usa una cadena larga y aleatoria
JWT_SECRET=clave

# --- Broker MQTT (debe coincidir con el usado en firmware/src/secrets.h) ---
MQTT_BROKER_URL=mqtts://xxxxxxxx.ala.us-east-1.emqxsl.com:8883
MQTT_USERNAME=tu_usuario_mqtt
MQTT_PASSWORD=tu_password_mqtt

# --- Puerto en el que correrá el servidor Express ---
PORT=3000
